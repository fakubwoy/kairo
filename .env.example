# Copy this to .env and fill in values
# Never commit .env to git!

# Flask
SECRET_KEY=your-secret-key-here-change-this

# Database (Railway will set DATABASE_URL automatically for Postgres)
# For local dev, SQLite is used by default
# DATABASE_URL=sqlite:///kairo.db

# LLM Configuration - pick one or both
# Option 1: OpenRouter (FREE - recommended for Railway deployment)
# Get free API key at https://openrouter.ai
# Free models: meta-llama/llama-3.2-3b-instruct:free, google/gemma-2-9b-it:free
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Option 2: Local Ollama (for local dev only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
